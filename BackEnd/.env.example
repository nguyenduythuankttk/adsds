# Database
ConnectionStrings__JolibiDatabase=Server=localhost;Port=3306;Database=<db_name>;User=<db_user>;Password=<db_password>

# JWT
Jwt__Key=<min_32_char_random_secret>
Jwt__Issuer=<issuer_name>
Jwt__Audience=<audience_name>
Jwt__ExpiryMinutes=480

# Resend Email API — lấy tại https://resend.com/api-keys
Resend__ApiKey=re_xxxxxxxxxxxxxxxxxxxx

# Frontend URL (dùng cho link trong email xác minh / đặt lại mật khẩu)
FrontendUrl=http://localhost:5173
