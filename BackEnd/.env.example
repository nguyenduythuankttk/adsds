# Database
ConnectionStrings__JolibiDatabase=Server=localhost;Port=3306;Database=<db_name>;User=<db_user>;Password=<db_password>

# JWT
Jwt__Key=<min_32_char_random_secret>
Jwt__Issuer=<issuer_name>
Jwt__Audience=<audience_name>
Jwt__ExpiryMinutes=480

# Resend Email API — lấy tại https://resend.com/api-keys
Resend__ApiKey=re_xxxxxxxxxxxxxxxxxxxx

# Frontend URL (dùng cho link trong email xác minh / đặt lại mật khẩu)
FrontendUrl=http://localhost:5173

# ─── SePay (TEST MODE) ────────────────────────────────────────────────────
# Đăng ký tại https://my.sepay.vn, tạo TK ảo + webhook → copy API key vào đây
SePay__TestMode=true
# API Key cho webhook (Cài đặt → Webhooks)
SePay__ApiKey=
# API Access Token (Công ty → API Access) để query giao dịch khi user bấm "Tôi đã chuyển khoản".
# Để trống sẽ fallback dùng SePay__ApiKey.
SePay__ApiToken=
# Tài khoản ngân hàng nhận tiền — cấu hình 1 lần, khách không cần chọn TK.
SePay__Account=
SePay__Bank=MB
SePay__AccountHolderName=
SePay__ReferencePrefix=JLB
