# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_USER=jolibi_user
MYSQL_PASSWORD=

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jolibi

# JWT — Key phải >= 32 ký tự
JWT_KEY=
JWT_ISSUER=dhstore.it.com
JWT_AUDIENCE=dhstore.it.com
JWT_EXPIRY_MINUTES=60

# Resend email API key (để trống nếu không dùng email)
RESEND_API_KEY=
