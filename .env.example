# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_USER=jolibi_user
MYSQL_PASSWORD=

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jolibi

# JWT — Key phải >= 32 ký tự
JWT_KEY=
JWT_ISSUER=dhstore.it.com
JWT_AUDIENCE=dhstore.it.com
JWT_EXPIRY_MINUTES=60

# Gmail App Password (tạo tại Google Account → Security → App passwords)
SMTP_PASSWORD=

# VietMap API Key (đăng ký tại maps.vietmap.vn)
VIETMAP_API_KEY=

# ─── SePay (TEST MODE) ────────────────────────────────────────────────────
# Tạo TK ảo + webhook trên https://my.sepay.vn → copy API key của webhook vào đây
SePay__TestMode=true
SePay__ApiKey=
SePay__Account=
SePay__Bank=MB
SePay__ReferencePrefix=JLB
